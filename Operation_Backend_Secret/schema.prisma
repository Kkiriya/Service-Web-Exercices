// prisma/schema.prisma

model Agent {
    agentId      Int          @id @default(autoincrement())
    connectionId Int          @unique
    pwd          String // Hashed w/ bcrypt
    role         Role         @default(RECRUIT)
    habilitation Habilitation
    mission      Mission[]
}

enum Role {
    RECRUIT
    AGENT
    CHIEF
}

enum Habilitation {
    CONFIDENTIAL
    SECRET
    ULTRA_SECRET
}

model Mission {
    missionId            Int    @id @default(autoincrement())
    title                String
    desc                 String
    confidentialityLevel Int
    status               Status @default(AVAILABLE)
    Reward               String
    agentId              Int
    agent                Agent  @relation(fields: [agentId], references: [agentId])
}

enum Status {
    AVAILABLE
    IN_PROGRESS
    SUCCESS
    FAILED
}
